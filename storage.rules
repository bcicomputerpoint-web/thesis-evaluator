rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ── Thesis PDFs ───────────────────────────────────────────────
    // Path: /theses/{uid}/{evalId}/thesis.pdf
    match /theses/{uid}/{evalId}/{filename} {
      allow read: if request.auth != null && (
        request.auth.uid == uid ||
        // Supervisor/RAC/DRC can read — use download tokens or signed URLs from server-side
        request.auth.token.role in ['supervisor', 'rac_member', 'drc_admin']
      );
      allow write: if request.auth != null &&
        request.auth.uid == uid &&
        request.resource.size < 50 * 1024 * 1024 && // 50 MB max
        request.resource.contentType == 'application/pdf';
    }

    // ── Generated Reports ─────────────────────────────────────────
    // Path: /reports/{uid}/{evalId}/report.pdf
    match /reports/{uid}/{evalId}/{filename} {
      allow read: if request.auth != null && (
        request.auth.uid == uid ||
        request.auth.token.role in ['supervisor', 'rac_member', 'drc_admin']
      );
      // Reports are only written server-side (Firebase Admin)
      allow write: if false;
    }

    // ── Profile photos ────────────────────────────────────────────
    match /avatars/{uid}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        request.auth.uid == uid &&
        request.resource.size < 2 * 1024 * 1024 && // 2 MB max
        request.resource.contentType.matches('image/.*');
    }
  }
}
